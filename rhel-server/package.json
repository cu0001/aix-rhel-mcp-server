{
  "name": "rhel-server",
  "version": "1.0.0",
  "description": "MCP Server for RHEL ppc64le operations via SSH",
  "main": "build/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "rhel",
    "ppc64le",
    "linux",
    "ssh"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "ssh2": "^1.17.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/ssh2": "^1.15.5",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
